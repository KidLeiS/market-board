{
  "name": "market-board",
  "version": "0.1.0",
  "description": "Desktop market dashboard for publicly traded instruments.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "productName": "Market Board",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "desktop": "npm run build && electron .",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "client": "vite --host 0.0.0.0",
    "server": "node server/cli.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "package:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "serverless-http": "^4.0.0",
    "yahoo-finance2": "^3.15.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.marketboard.desktop",
    "productName": "Market Board",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
